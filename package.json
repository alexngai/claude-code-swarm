{
  "name": "claude-code-swarm",
  "version": "0.3.10",
  "description": "Claude Code plugin for launching agent teams from openteams topologies with MAP observability",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./config": "./src/config.mjs",
    "./roles": "./src/roles.mjs",
    "./template": "./src/template.mjs",
    "./agent-generator": "./src/agent-generator.mjs"
  },
  "bin": {
    "swarm-bootstrap": "./scripts/bootstrap.mjs",
    "swarm-sidecar": "./scripts/map-sidecar.mjs",
    "swarm-hook": "./scripts/map-hook.mjs",
    "swarm-load-team": "./scripts/team-loader.mjs",
    "swarm-generate-agents": "./scripts/generate-agents.mjs"
  },
  "dependencies": {
    "@multi-agent-protocol/sdk": "^0.1.4",
    "agentic-mesh": "^0.2.0",
    "js-yaml": "^4.1.0"
  },
  "peerDependencies": {
    "agent-inbox": "*",
    "opentasks": "*",
    "swarmkit": "*"
  },
  "peerDependenciesMeta": {
    "agent-inbox": {
      "optional": true
    },
    "opentasks": {
      "optional": true
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config e2e/vitest.config.e2e.mjs",
    "test:e2e:tier1": "vitest run --config e2e/vitest.config.e2e.mjs -t tier1",
    "test:e2e:tier2": "vitest run --config e2e/vitest.config.e2e.mjs -t tier2",
    "test:e2e:tier3": "vitest run --config e2e/vitest.config.e2e.mjs -t tier3",
    "test:e2e:tier4": "vitest run --config e2e/vitest.config.e2e.mjs -t tier4",
    "test:e2e:tier5": "vitest run --config e2e/vitest.config.e2e.mjs -t tier5",
    "test:e2e:tier7": "vitest run --config e2e/vitest.config.e2e.mjs -t tier7",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/sync-version.mjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/sync-version.mjs",
    "version:major": "npm version major --no-git-tag-version && node scripts/sync-version.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "agent-inbox": "^0.1.9",
    "minimem": "^0.1.0",
    "opentasks": "^0.0.6",
    "skill-tree": "^0.1.5",
    "vitest": "^4.0.18",
    "ws": "^8.0.0"
  }
}
